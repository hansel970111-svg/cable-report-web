{
  "name": "projects",
  "version": "0.1.1",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "desktop:build:py": "node ./scripts/build-python-workers.mjs",
    "desktop:dev": "node ./scripts/desktop-dev.mjs",
    "desktop:dist": "node ./scripts/desktop-dist.mjs",
    "desktop:dist:mac": "node ./scripts/desktop-dist.mjs mac",
    "desktop:dist:win": "node ./scripts/desktop-dist.mjs win",
    "dev": "node ./scripts/dev.mjs",
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint . --max-warnings=0",
    "start": "node ./scripts/start.mjs",
    "start:browser": "node scripts/start.mjs --browser-dev",
    "ts-check": "tsc -p tsconfig.json",
    "test:e2e:browser": "playwright test --project=chromium",
    "test:perf": "playwright test tests/e2e/report-editor-performance.spec.ts --project=chromium --workers=1",
    "test:unit": "vitest run",
    "test:python": "node scripts/run-python.mjs -m pytest -q",
    "test": "corepack pnpm test:unit && corepack pnpm test:python",
    "check:fast": "corepack pnpm lint && corepack pnpm ts-check && corepack pnpm test:unit",
    "verify:runtime-surface": "node scripts/verify-runtime-surface.mjs"
  },
  "dependencies": {
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@tanstack/react-virtual": "3.14.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.469.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-day-picker": "9.13.0",
    "react-dom": "19.2.7",
    "tailwind-merge": "2.6.0",
    "tw-animate-css": "1.4.0",
    "xlsx": "file:vendor/xlsx-0.20.3.tgz",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@tailwindcss/postcss": "4.1.18",
    "@types/jest-axe": "3.5.9",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-builder-squirrel-windows": "26.15.3",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "only-allow": "1.2.2",
    "playwright-core": "1.61.1",
    "tailwindcss": "4.1.18",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "9.15.9"
  },
  "pnpm": {
    "overrides": {
      "@babel/core@7.28.6": "7.29.7",
      "ajv@6.12.6": "6.14.0",
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@2.0.2": "2.0.3",
      "esbuild@0.27.3": "0.28.1",
      "fast-uri": "3.1.2",
      "flatted": "3.4.2",
      "form-data": "4.0.6",
      "@electron/get@5.0.0>undici": "7.28.0",
      "jsdom@29.1.1>undici": "7.28.0",
      "js-yaml@4.1.1": "4.3.0",
      "lodash": "4.18.1",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@9.0.5": "9.0.7",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.5",
      "postcss": "8.5.16",
      "tar@7.5.15": "7.5.19",
      "tmp": "0.2.7",
      "node-gyp@12.3.0>undici": "6.27.0"
    }
  },
  "build": {
    "appId": "com.cable.report.generator",
    "productName": "Cable Report Generator",
    "directories": {
      "output": "release"
    },
    "publish": null,
    "compression": "maximum",
    "asar": false,
    "afterPack": "scripts/electron-after-pack.cjs",
    "files": [
      "electron/**/*",
      "next-build/standalone/**/*",
      "package.json",
      "next.config.mjs",
      "!node_modules",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "M138-DE46-OOB-Cat5e.pdf",
          "M138-DE46-D-P-cross-LC.pdf",
          "M138-DE46-P-A-MPO.pdf"
        ]
      },
      {
        "from": "worker-bin",
        "to": "bin",
        "filter": [
          "pdf_worker*"
        ]
      }
    ],
    "mac": {
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
